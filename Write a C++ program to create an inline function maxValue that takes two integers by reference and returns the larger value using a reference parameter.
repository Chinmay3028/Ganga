#include <iostream>
using namespace std;

// Inline function using reference parameters
inline void maxValue(int &a, int &b, int &max)
{
    if (a > b)
        max = a;
    else
        max = b;
}

int main()
{
    int num1, num2, result;

    cout << "Enter two integers: ";
    cin >> num1 >> num2;

    maxValue(num1, num2, result);

    cout << "Larger value is: " << result;

    return 0;
}
